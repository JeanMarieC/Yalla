# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit real keys.

# --- Supabase (Project Settings -> API Keys) ---
# Project URL — same value in both (the NEXT_PUBLIC_ one is for the browser,
# the plain one is for server-side scripts).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
# Publishable key (sb_publishable_...). Browser-safe; protected by RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key (sb_secret_...) — SERVER ONLY, bypasses Row Level Security.
# Never expose this to the browser and never prefix it with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# --- Mapbox (account.mapbox.com -> Tokens) ---
# Public token, used by Mapbox GL in the browser.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- AI / LLM (server-side only, never exposed to the client) ---
# Provider: Google Gemini (free tier). Get a key at aistudio.google.com/apikey
GEMINI_API_KEY=
