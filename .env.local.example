# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit real keys.

# --- Supabase (Project Settings -> API) ---
# Safe to expose to the browser (hence NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Mapbox (account.mapbox.com -> Tokens) ---
# Public token, used by Mapbox GL in the browser.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- AI / LLM (server-side only, never exposed to the client) ---
# Default provider is Anthropic (Claude). Rename if you use another LLM.
ANTHROPIC_API_KEY=
